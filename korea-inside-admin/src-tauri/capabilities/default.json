{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "platforms": ["windows"],
  "permissions": [
    "allow-select-repository",
    "allow-disconnect-repository",
    "allow-preview-repository-export",
    "allow-export-repository-inventory",
    "allow-save-vercel-access-token",
