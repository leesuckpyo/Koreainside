    "allow-delete-vercel-access-token",
    "allow-test-vercel-analytics-connection",
    "allow-get-vercel-analytics-summary",
    "allow-get-site-status-report",
    "allow-get-search-console-client-status",
    "allow-import-search-console-oauth-json",
